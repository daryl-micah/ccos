# API base URL as seen by the BROWSER. Relative = same-origin through the Next
# BFF (recommended; the browser never calls the API directly). Baked in at build
# time because it is NEXT_PUBLIC_*.
NEXT_PUBLIC_API_URL=/api/v1

# Server-side rewrite target: where the Next BFF forwards /api/v1/* to the API.
# Read at runtime (not baked in). In Docker use the service name; for local
# `next dev` against a locally-running API use http://localhost:8000.
API_INTERNAL_URL=http://api:8000

# --- Clerk auth ---
# Publishable key is NEXT_PUBLIC_* (baked in at build time). Get keys at
# https://dashboard.clerk.com. In Docker deploys these are passed as build
# args in docker-compose.yml, sourced from the host's .env file.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# Secret key, server-side only. Read at runtime (not baked in).
CLERK_SECRET_KEY=
