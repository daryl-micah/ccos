# --- Database ---
# Async driver (asyncpg) for the app. For local Docker Postgres:
DATABASE_URL=postgresql+asyncpg://ccos:ccos@localhost:5433/ccos

# --- Redis (Celery / cache, used from Phase 3+) ---
REDIS_URL=redis://localhost:6379/0

# --- Instagram collector (Phase 3, optional) ---
# Instaloader needs NO Facebook Graph API token, but Instagram blocks most
# anonymous scraping. Provide a login to make collection reliable.
# INSTAGRAM_USERNAME=
# INSTAGRAM_PASSWORD=

# --- App ---
ENV=development
API_V1_PREFIX=/api/v1
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000
