# --- Database ---
# Async driver (asyncpg) for the app. For local Docker Postgres:
DATABASE_URL=postgresql+asyncpg://ccos:ccos@localhost:5433/ccos

# --- Redis (Celery / cache, used from Phase 3+) ---
REDIS_URL=redis://localhost:6379/0

# --- Instagram collector (Phase 3) ---
# A single shared account authenticates all collection. Username/password is
# tried first; if it fails (2FA/challenge/block) it falls back to the sessionid
# cookie (get it from the `sessionid` cookie of a logged-in instagram.com tab).
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=
INSTAGRAM_SESSIONID=

# --- AI insights (Phase 8, optional) — powered by Groq ---
# Get a key at https://console.groq.com. Leave blank to disable the feature.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Clerk auth (multi-tenancy rollout, Phase 2+) ---
# Same secret key as apps/web's CLERK_SECRET_KEY. Used to verify session JWTs
# (via Clerk's Backend API JWKS endpoint) and to extract org_id/org_role.
CLERK_SECRET_KEY=

# --- App ---
ENV=development
API_V1_PREFIX=/api/v1
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000
